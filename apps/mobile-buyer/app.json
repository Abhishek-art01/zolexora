    "android": { "package": "com.zolexora.buyer", "adaptiveIcon": { "foregroundImage": "./assets/icon.png", "backgroundColor": "#FFB800" } },
    "plugins": ["expo-router", "expo-secure-store"],
    "extra": { "apiUrl": "https://api.zolexora.com/api" }
  }
}
