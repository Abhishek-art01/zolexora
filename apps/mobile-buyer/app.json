{
  "expo": {
    "name": "Zolexora",
    "slug": "zolexora-buyer",
    "version": "1.0.0",
    "scheme": "zolexora",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#FFB800"
    },
    "ios": {
      "bundleIdentifier": "com.zolexora.buyer",
      "supportsTablet": false
    },
    "android": {
      "package": "com.zolexora.buyer",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFB800"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "apiUrl": "https://api.zolexora.com/api",
      "localApiUrl": "http://localhost:8000/api",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e6579e67-1627-4e2f-b13f-de4c08eec72c"
      }
    }
  }
}
